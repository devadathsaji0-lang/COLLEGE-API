const express = require('express');
const mongoose = require('mongoose');
const cors = require('cors');

const app = express();
app.use(cors());
app.use(express.json());

// ===== 1. ഇവിടെ നിന്റെ MongoDB Connection String മാറ്റണം =====
// MongoDB Atlas -> Database -> Connect -> Drivers -> Connection string copy ചെയ്യ്
// <password> മാറ്റി നിന്റെ യഥാർത്ഥ password ഇടണം
// അവസാനം /collegeDB ചേർക്കണം
const MONGO_URI = 'mongodb+srv://devadath:yourRealPassword@cluster0.xxxxx.mongodb.net/collegeDB?retryWrites=true&w=majority';

mongoose.connect(MONGO_URI)
  .then(() => console.log('MongoDB connected'))
  .catch(err => console.log('MongoDB Error:', err));

// ===== Schema =====
const DataSchema = new mongoose.Schema({
  students: Array,
  courses: Array,
  faculty: Array,
  attendance: Array,
  todos: Array
});

const DataModel = mongoose.model('Data', DataSchema);

// ===== API Routes =====

// GET - എല്ലാ data-യും കിട്ടാൻ
app.get('/api/data', async (req, res) => {
  try {
    let data = await DataModel.findOne();
    if (!data) {
      data = new DataModel({ students: [], courses: [], faculty: [], attendance: [], todos: [] });
      await data.save();
    }
    res.json(data);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// POST - എല്ലാ data-യും save/update ചെയ്യാൻ
app.post('/api/data', async (req, res) => {
  try {
    let data = await DataModel.findOne();
    if (!data) {
      data = new DataModel(req.body);
    } else {
      data.students = req.body.students || [];
      data.courses = req.body.courses || [];
      data.faculty = req.body.faculty || [];
      data.attendance = req.body.attendance || [];
      data.todos = req.body.todos || [];
    }
    await data.save();
    res.json({ message: 'Data saved successfully', data });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// ===== 2. ഇത് Render-ന് വേണ്ടി നിർബന്ധമാണ് =====
const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
  console.log('Server running on port ' + PORT);
});
